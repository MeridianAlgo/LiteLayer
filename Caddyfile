{
    # local_certs issues a self-signed CA trusted by this machine only.
    # Replace with a real domain + ACME block when you have DNS.
    local_certs
    email admin@litelayer.local
}

# Serve on all interfaces — Tailscale, WireGuard, ZeroTier, LAN all reach this.
:443 {
    reverse_proxy localhost:8000 {
        header_up X-Forwarded-Proto https
    }
    encode gzip zstd

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }
}

:80 {
    redir https://{host}{uri} permanent
}

